{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "skipLibCheck":     true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@loykin/designkit": ["../src/index.ts"],
      "@/*":              ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
